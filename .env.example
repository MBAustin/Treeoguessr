# Copy to .env.local and fill in. In production, set these in the Vercel dashboard.

# Secret used to encrypt the per-round answer token. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ROUND_SECRET=

# Supabase (optional — auth & progress are disabled until both are set).
# Dashboard → Project Settings → API:
#   Project URL  -> NEXT_PUBLIC_SUPABASE_URL
#   anon / public (a.k.a. publishable) key -> NEXT_PUBLIC_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
